# Конфигурация для RAG-ассистента
# Скопируйте этот файл в .env и заполните значения

# ============================================
# ВЫБОР ПРОВАЙДЕРА API
# ============================================
# Установите USE_PROXYAPI=true чтобы использовать ProxyAPI вместо прямого OpenAI API
# ProxyAPI — российский сервис-прокси для доступа к моделям OpenAI, Anthropic и др.
# Получите ключ на https://proxyapi.ru/
USE_PROXYAPI=false

# API ключ OpenAI (используется если USE_PROXYAPI=false)
# Получите ключ на https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# API ключ ProxyAPI (используется если USE_PROXYAPI=true)
# Получите ключ на https://proxyapi.ru/
PROXYAPI_KEY=your_proxyapi_key_here

# Базовый URL для ProxyAPI (опционально, по умолчанию https://api.proxyapi.ru/openai/v1)
# PROXYAPI_BASE_URL=https://api.proxyapi.ru/openai/v1

# ============================================
# TELEGRAM БОТ
# ============================================
# Токен Telegram бота (опционально, для режима Telegram бота)
# Получите токен у @BotFather в Telegram
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ============================================
# НАСТРОЙКИ МОДЕЛЕЙ
# ============================================
# Модель для генерации ответов (через ProxyAPI доступны: gpt-4o, gpt-4o-mini, gpt-4-turbo и др.)
# MODEL_NAME=gpt-3.5-turbo
# TEMPERATURE=0.7

# Модель для эмбеддингов (через ProxyAPI доступны: text-embedding-3-small, text-embedding-3-large)
# EMBEDDING_MODEL=text-embedding-3-small
# Альтернативы: text-embedding-3-large, text-embedding-ada-002

# ============================================
# НАСТРОЙКИ ХРАНИЛИЩА
# ============================================
# Директория для сохранения данных ChromaDB
# CHROMA_PERSIST_DIR=./chroma_db

# Файл кеша ответов
# CACHE_FILE=cache.json

# Файл базы данных логов
# LOGS_DB_PATH=logs.db

